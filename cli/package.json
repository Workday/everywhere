{
  "name": "@workday/wdcli-plugin-everywhere",
  "description": "wdcli plugin for managing Workday Everywhere plugins",
  "version": "0.1.0",
  "author": "Workday",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "lib/index.js",
  "engines": {
    "node": ">=20.11.1"
  },
  "files": [
    "lib",
    "oclif.manifest.json"
  ],
  "keywords": [
